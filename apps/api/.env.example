NODE_ENV=development
PORT=4000

# Local Docker: postgresql://postgres:postgres@localhost:5434/incident_intelligence
# Production (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:**DB_PASSWORD***.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Local Docker: redis://localhost:6380
# Production (Upstash): rediss://default:token@xxx.upstash.io:6379
REDIS_URL=redis://default:****PASS***@amusing-ladybug-98736.upstash.io:6379

WEB_ORIGIN=http://localhost:3000
SESSION_TTL_DAYS=7

# Same Client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID in apps/web/.env.local
GOOGLE_CLIENT_ID=***ENTER_CLIENT_ID***.apps.googleusercontent.com
